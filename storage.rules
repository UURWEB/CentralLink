rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.uid == "YDx6lpApdWWaOAYRSoMBvBSOhwq1";
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    match /centralLink/avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if signedIn()
        && request.auth.uid == uid
        && isImage()
        && request.resource.size < 3 * 1024 * 1024;
      allow delete: if signedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /centralLink/postImages/{uid}/{fileName} {
      allow read: if true;
      allow write: if signedIn()
        && request.auth.uid == uid
        && isImage()
        && request.resource.size < 5 * 1024 * 1024;
      allow delete: if signedIn() && (request.auth.uid == uid || isAdmin());
    }
  }
}
